QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen3.5-flash
QUESTION_KIND_MODEL=
QUESTION_KIND_CONFIDENCE_THRESHOLD=0.75
QUESTION_KIND_MAX_OUTPUT_TOKENS=200
# 如果希望所有 qwen_* 配置统一使用同一个问答模型，改这里即可。
# 例如统一切到 qwen-plus：QWEN_CHAT_MODEL=qwen-plus
#
# QUESTION_KIND_MODEL 用于题型分类，可以单独指定一个更轻的模型，例如 glm-4.5-air、qwen-turbo 等。
# 如果留空，则继续使用当前的规则兜底，不额外调用题型分类模型。
#
# 如果只想覆盖某个配置，也可以单独设置对应环境变量：
# QWEN_DEFAULT_MODEL=qwen-max
# QWEN_TURBO_MODEL=qwen-turbo
# QWEN_MAX_RERANK_MODEL=qwen-max
# QWEN_PLUS_RERANK_MODEL=qwen-plus
# QWEN_MAX_LLM_TOP5_MODEL=qwen-max
# QWEN_MAX_CE_TOP5_MODEL=qwen-max
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
CROSS_ENCODER_MODEL=BAAI/bge-reranker-v2-m3
CROSS_ENCODER_DEVICE=cuda
HNSW_M=32
HNSW_EF_CONSTRUCTION=80
HNSW_EF_SEARCH=64

TEXT_CHUNK_SIZE=500
TEXT_CHUNK_OVERLAP=80
